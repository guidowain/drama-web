# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# JWT secret — generate a random 32+ char string
JWT_SECRET=your-very-secret-jwt-key-change-this

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Analytics 4 numeric property ID for the Data API
GOOGLE_ANALYTICS_PROPERTY_ID=123456789

# Optional: Google Analytics API access using OAuth with a real Google user
GOOGLE_ANALYTICS_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_ANALYTICS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ANALYTICS_REFRESH_TOKEN=your-oauth-refresh-token
